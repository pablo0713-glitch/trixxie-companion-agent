# =============================================================
# Model Provider
# Options: anthropic | openai | openrouter | gemini | grok | ollama | lm_studio
# =============================================================
MODEL_PROVIDER=anthropic

# === Anthropic (Claude) ===
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024

# === OpenAI ===
# https://platform.openai.com
# Set MODEL_PROVIDER=openai
#OPENAI_API_KEY=sk-...
#OPENAI_MODEL=gpt-4o

# === OpenRouter ===
# https://openrouter.ai — access many models through one key
# Set MODEL_PROVIDER=openrouter
#OPENAI_API_KEY=sk-or-...
#OPENAI_MODEL=anthropic/claude-sonnet-4-5

# === Google Gemini (OpenAI-compatible endpoint) ===
# https://aistudio.google.com/apikey
# Set MODEL_PROVIDER=gemini
#OPENAI_API_KEY=AIza...
#OPENAI_MODEL=gemini-2.0-flash

# === Grok (xAI) ===
# https://console.x.ai
# Set MODEL_PROVIDER=grok
#OPENAI_API_KEY=xai-...
#OPENAI_MODEL=grok-3

# === Ollama (local) ===
# https://ollama.com — run models locally, no API key required
# Set MODEL_PROVIDER=ollama
#OLLAMA_BASE_URL=http://localhost:11434/v1
#OLLAMA_MODEL=llama3.2

# === LM Studio (local) ===
# https://lmstudio.ai — run models locally via LM Studio's built-in server
# Set MODEL_PROVIDER=lm_studio
#OPENAI_BASE_URL=http://localhost:1234/v1
#OPENAI_MODEL=llama-3.2-3b-instruct

# =============================================================
# Discord
# =============================================================
DISCORD_TOKEN=
DISCORD_ALLOWED_GUILD_IDS=          # Comma-separated snowflakes, empty = all guilds
DISCORD_ACTIVE_CHANNEL_IDS=         # Channels where bot responds without @mention

# =============================================================
# Second Life — HTTP Bridge
# =============================================================
SL_BRIDGE_HOST=0.0.0.0
SL_BRIDGE_PORT=8080
SL_BRIDGE_SECRET=change_this_to_a_long_random_string

# =============================================================
# Web Search
# =============================================================
# Provider options: serper | brave
# Serper: https://serper.dev — 2,500 free searches/month
# Brave:  https://api.search.brave.com
SEARCH_PROVIDER=serper
SEARCH_API_KEY=

# =============================================================
# Rate Limiting
# =============================================================
RATE_LIMIT_CAPACITY=5               # Token bucket size per user
RATE_LIMIT_REFILL_RATE=0.5          # Tokens per second (1 req per 2s sustained)

# =============================================================
# Memory
# =============================================================
MEMORY_DIR=./data/memory
NOTES_DIR=./data/notes
MEMORY_MAX_HISTORY=20               # Max conversation turns kept per channel
OWNER_NAME=                         # Your name — used in memory notes and context
