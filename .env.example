# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024

# === Discord ===
DISCORD_TOKEN=
DISCORD_ALLOWED_GUILD_IDS=          # Comma-separated snowflakes, empty = all guilds

# === Second Life — Bot Avatar ===
# Create a second SL account for Trixxie, then fill these in.
# She will log in as a real avatar and receive/send IMs directly.
# Install the SL client library first: pip install pyogp.lib.base
SL_BOT_FIRSTNAME=Trixxie
SL_BOT_LASTNAME=Carissa
SL_BOT_PASSWORD=

# === Second Life — HTTP Bridge (optional, for testing only) ===
# Leave these set if you want a local test endpoint without a bot account.
# In production with the bot avatar, the bridge is not used for messaging.
SL_BRIDGE_HOST=0.0.0.0
SL_BRIDGE_PORT=8080
SL_BRIDGE_SECRET=change_this_to_a_long_random_string

# === Web Search ===
# Provider options: serper | brave | tavily
# Serper: https://serper.dev — 2,500 free searches/month
SEARCH_PROVIDER=serper
SEARCH_API_KEY=

# === Rate Limiting ===
RATE_LIMIT_CAPACITY=5               # Token bucket size per user
RATE_LIMIT_REFILL_RATE=0.5          # Tokens per second (1 req per 2s sustained)

# === Memory ===
MEMORY_DIR=./data/memory
NOTES_DIR=./data/notes
MEMORY_MAX_HISTORY=20               # Max conversation turns kept per channel
